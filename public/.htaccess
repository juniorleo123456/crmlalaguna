# Activar el motor de reescritura (necesario para rutas amigables)

RewriteEngine On

# 1. Si el archivo o carpeta solicitada existe físicamente → servirla directamente

# (imágenes, css, js, favicon, etc.)

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 2. Redirigir TODAS las peticiones (excepto las que ya existen) a index.php

RewriteRule ^(.\*)$ index.php [QSA,L]

# =============================================

# Seguridad básica adicional

# =============================================

# Denegar acceso directo a archivos sensibles dentro de public/

<FilesMatch "\.(env|ini|log|sql|md|gitignore|htaccess)$">
Order allow,deny
Deny from all
</FilesMatch>

# Evitar mostrar directorios (listado de archivos si no hay index)

Options -Indexes

# Forzar HTTPS en producción (comentar en desarrollo local si no tienes SSL)

# RewriteCond %{HTTPS} off

# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Cabeceras de seguridad básicas (opcional pero recomendado)

Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "DENY"
Header set X-XSS-Protection "1; mode=block"
